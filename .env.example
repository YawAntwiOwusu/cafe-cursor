# ===========================================
# Cafe Cursor Accra - Environment Variables
# ===========================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# Database (PostgreSQL only — Neon, Supabase, Vercel Postgres, etc.)
# Neon: use the "pooled" connection for DATABASE_URL and "direct" (non-pooler host) for DIRECT_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Resend (https://resend.com) — verify your domain for production FROM_EMAIL
RESEND_API_KEY="re_your_api_key_here"
FROM_EMAIL="Cafe Cursor Accra <onboarding@resend.dev>"

# Admin panel (/admin)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CafeCursorAccra"

# Session signing (use a long random string in production)
SESSION_SECRET="generate_a_long_random_string_for_production"
